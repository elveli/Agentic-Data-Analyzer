# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DB_*: Postgres/pgvector connection used by the vector-store pipeline step.
# These match docker-compose.yml's postgres service - run `docker-compose up -d postgres`
# before `npm run dev` if you're not running the full stack via Docker Compose.
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="agent_admin"
DB_PASS="local_password"
DB_NAME="agentic_workspace"
# DB_SSL: leave unset/false for local Docker Postgres (no SSL support). Terraform sets this
# to "true" for the real ECS deployment, since RDS rejects plaintext connections by default.
DB_SSL="false"
